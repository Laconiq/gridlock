/* ============================================================
   VOID_PROTOCOL — Dynamic Crosshair
   ============================================================ */

.crosshair-root {
    --primary:          #8ff5ff;
    --on-surface:       #ffffff;
    --outline:          #767576;

    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
    align-items: center;
    justify-content: center;
}

.crosshair__canvas {
    width: 120px;
    height: 120px;
}
