<ui:UXML xmlns:ui="UnityEngine.UIElements">
    <ui:Style src="../DesignTokens.uss" />
    <ui:Style src="InteractionPrompt.uss" />

    <ui:VisualElement name="interaction-root" class="gridlock-ui interaction-root" picking-mode="Ignore">

        <ui:VisualElement name="prompt" class="interaction__prompt" picking-mode="Ignore">

            <ui:VisualElement name="key-container" class="interaction__key" picking-mode="Ignore">
                <ui:VisualElement name="key-fill" class="interaction__key-fill" picking-mode="Ignore" />
                <ui:Label name="key-label" text="E" class="interaction__key-label" picking-mode="Ignore" />
            </ui:VisualElement>

            <ui:VisualElement class="interaction__text-group" picking-mode="Ignore">
                <ui:Label name="action-text" text="INTERACT" class="interaction__action" picking-mode="Ignore" />
                <ui:Label name="hold-hint" text="HOLD" class="interaction__hold-hint" picking-mode="Ignore" />
            </ui:VisualElement>

        </ui:VisualElement>

    </ui:VisualElement>
</ui:UXML>
